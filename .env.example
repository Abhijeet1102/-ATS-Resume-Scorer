# Groq API Configuration (Required for AI Suggestions)
# Get your key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Supabase Configuration (Optional)
# If left blank, the app will run in "Local Mock Mode" (no database connection required)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=
